{
    "name": "justinholtweb/craft-rabbits",
    "description": "Webflow-style visual component builder for Craft CMS",
    "type": "craft-plugin",
    "version": "5.0.0",
    "keywords": [
        "craft",
        "cms",
        "craftcms",
        "craft-plugin",
        "rabbits",
        "visual-builder",
        "component-builder",
        "webflow"
    ],
    "license": "proprietary",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Justin Holt",
            "homepage": "https://justinholt.com"
        }
    ],
    "support": {
        "docs": "https://craft-rabbits.com/docs",
        "source": "https://github.com/justinholtweb/craft-rabbits",
        "issues": "https://github.com/justinholtweb/craft-rabbits/issues"
    },
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.3.0"
    },
    "require-dev": {
        "craftcms/ecs": "dev-main",
        "craftcms/phpstan": "dev-main",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "justinholtweb\\rabbits\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "justinholtweb\\rabbits\\tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true,
            "craftcms/generator": true
        }
    },
    "extra": {
        "name": "Rabbits",
        "handle": "rabbits",
        "developer": "Justin Holt",
        "developerUrl": "https://justinholt.com",
        "documentationUrl": "https://craft-rabbits.com/docs",
        "changelogUrl": "https://raw.githubusercontent.com/justinholtweb/craft-rabbits/main/CHANGELOG.md",
        "class": "justinholtweb\\rabbits\\Plugin"
    }
}
