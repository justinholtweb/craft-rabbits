{% import '_includes/forms.twig' as forms %}

{{ forms.textField({
  label: 'Max Components'|t('rabbits'),
  instructions: 'Maximum number of components allowed. Set to 0 for unlimited.'|t('rabbits'),
  id: 'maxComponents',
  name: 'maxComponents',
  value: settings.maxComponents,
  type: 'number',
  min: 0,
}) }}

{{ forms.lightswitchField({
  label: 'Enable Twig Cache'|t('rabbits'),
  instructions: 'Cache compiled Twig output for faster rendering.'|t('rabbits'),
  id: 'enableTwigCache',
  name: 'enableTwigCache',
  on: settings.enableTwigCache,
}) }}

{{ forms.lightswitchField({
  label: 'Enable Custom CSS'|t('rabbits'),
  instructions: 'Allow custom CSS per component.'|t('rabbits'),
  id: 'enableCustomCss',
  name: 'enableCustomCss',
  on: settings.enableCustomCss,
}) }}

{{ forms.lightswitchField({
  label: 'Enable Custom JS'|t('rabbits'),
  instructions: 'Allow custom JavaScript per component. Disabled by default for security.'|t('rabbits'),
  id: 'enableCustomJs',
  name: 'enableCustomJs',
  on: settings.enableCustomJs,
}) }}

{{ forms.textField({
  label: 'Compiled Path'|t('rabbits'),
  instructions: 'Directory for compiled Twig templates (relative to templates root).'|t('rabbits'),
  id: 'compiledPath',
  name: 'compiledPath',
  value: settings.compiledPath,
  class: 'code',
}) }}

{{ forms.selectField({
  label: 'CSS Framework'|t('rabbits'),
  instructions: 'Choose a CSS framework integration. With Tailwind, add your compiled components to your Tailwind `content` paths (or safelist) so utility classes are not purged.'|t('rabbits'),
  id: 'cssFramework',
  name: 'cssFramework',
  value: settings.cssFramework,
  options: [
    { label: 'None'|t('rabbits'), value: 'none' },
    { label: 'Tailwind CSS'|t('rabbits'), value: 'tailwind' },
  ],
}) }}

{{ forms.lightswitchField({
  label: 'Load Alpine.js'|t('rabbits'),
  instructions: 'Auto-include Alpine.js (pinned CDN build) alongside the Rabbits runtime, so x-* attribute bindings work. You can also call {{ rabbits_alpine() }} manually.'|t('rabbits'),
  id: 'loadAlpine',
  name: 'loadAlpine',
  on: settings.loadAlpine,
}) }}

{{ forms.lightswitchField({
  label: 'Enable Smoke editing'|t('rabbits'),
  instructions: 'Emit Smoke front-end editing attributes on field-bound nodes so built components can be edited in place. Requires the Smoke plugin. Recompile components after changing this.'|t('rabbits'),
  id: 'enableSmokeEditing',
  name: 'enableSmokeEditing',
  on: settings.enableSmokeEditing,
}) }}
